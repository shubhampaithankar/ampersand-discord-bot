# Copy to .env and fill. Runtime values live in /home/shubham/ampersand/.env on the mini-pc
# (deployed by CI) — NOT committed. No secrets in this file.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_NAME=
DISCORD_TOKEN=
DISCORD_PERMISSION_INTEGER=
MONGO_URL=mongodb://mongo:27017/ampersand
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Valkey runs with NO auth on secure-net -> keep USERNAME/PASSWORD blank
# (a stale value makes ioredis send AUTH -> WRONGPASS -> redis dead).
REDIS_URL=redis://valkey:6379
REDIS_USERNAME=
REDIS_PASSWORD=
ERROR_WEBHOOK_URL=
